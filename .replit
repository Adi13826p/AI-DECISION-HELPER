modules = ["nodejs-20", "web", "bash", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Canvas Preview"

[[workflows.workflow]]
name = "Canvas Preview"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"
isCanvasWorkflow = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 BASE_PATH=/__mockup pnpm --filter @workspace/mockup-sandbox run dev"
waitForPort = 8080

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 21102
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]

[userenv.development]

[userenv.production]
